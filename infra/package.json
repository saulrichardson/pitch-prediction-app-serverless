{
  "name": "@pitch/infra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "pitch-infra": "bin/pitch-infra.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "synth": "AWS_REGION=${AWS_REGION:-us-east-1} AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION:-us-east-1} cdk synth",
    "deploy": "AWS_REGION=${AWS_REGION:-us-east-1} AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION:-us-east-1} cdk deploy PitchSequenceModelStack PitchSequenceServerlessStack --require-approval never",
    "deploy:model": "AWS_REGION=${AWS_REGION:-us-east-1} AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION:-us-east-1} cdk deploy PitchSequenceModelStack --require-approval never",
    "deploy:serverless": "AWS_REGION=${AWS_REGION:-us-east-1} AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION:-us-east-1} cdk deploy PitchSequenceServerlessStack --require-approval never"
  },
  "devDependencies": {
    "aws-cdk": "^2.1036.0",
    "aws-cdk-lib": "^2.253.1",
    "constructs": "^10.4.3",
    "tsx": "^4.21.0"
  }
}
